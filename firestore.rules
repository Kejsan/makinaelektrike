rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        getUserData().role == 'admin';
    }

    function isDealerOwnerById(dealerId) {
      return isAuthenticated() && (
        dealerId == request.auth.uid ||
        (
          exists(/databases/$(database)/documents/dealers/$(dealerId)) &&
          get(/databases/$(database)/documents/dealers/$(dealerId)).data.ownerUid == request.auth.uid
        )
      );
    }

    function isDealerOwner(dealerData) {
      return isAuthenticated() && dealerData.ownerUid == request.auth.uid;
    }

    function isPublicDealer(dealerData) {
      return dealerData.approved == true &&
        dealerData.isActive == true &&
        dealerData.isDeleted != true;
    }

    function isPublicListing(listingData) {
      return listingData.status == 'approved' || listingData.status == 'active';
    }

    function isListingOwner(listingData) {
      return isAuthenticated() && (
        listingData.ownerUid == request.auth.uid ||
        isDealerOwnerById(listingData.dealerId)
      );
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (isUser(userId) || isAdmin());

      allow create: if isUser(userId) &&
        !exists(/databases/$(database)/documents/users/$(userId)) &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.email == request.auth.token.email &&
        (
          request.resource.data.role == 'user' ||
          request.resource.data.role == 'pending'
        ) &&
        (
          !('status' in request.resource.data) ||
          request.resource.data.status == 'pending'
        );

      allow update: if isUser(userId) &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'role',
          'status',
          'uid',
        ]);

      allow delete: if isAdmin();

      match /favourites/{favId} {
        allow read, write: if isUser(userId);
      }
    }

    match /dealers/{dealerId} {
      allow read: if isAdmin() || isDealerOwner(resource.data) || isPublicDealer(resource.data);

      allow create: if isAdmin() || (
        isAuthenticated() &&
        request.resource.data.ownerUid == request.auth.uid &&
        request.resource.data.approved != true &&
        request.resource.data.isActive != true &&
        request.resource.data.isDeleted != true &&
        request.resource.data.status == 'pending'
      );

      allow update: if isAdmin() || (
        isDealerOwner(resource.data) &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'approved',
          'approvedAt',
          'rejectedAt',
          'rejectionReason',
          'isActive',
          'isDeleted',
          'deletedAt',
          'status',
          'ownerUid',
          'createdBy',
        ])
      );

      allow delete: if isAdmin();
    }

    match /listings/{listingId} {
      allow read: if isAdmin() || isListingOwner(resource.data) || isPublicListing(resource.data);

      allow create: if isAdmin() || (
        isAuthenticated() &&
        request.resource.data.ownerUid == request.auth.uid &&
        isDealerOwnerById(request.resource.data.dealerId) &&
        request.resource.data.status == 'pending'
      );

      allow update: if isAdmin() || (
        isListingOwner(resource.data) &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'status',
          'approvedAt',
          'rejectedAt',
          'rejectionReason',
          'dealerId',
          'ownerUid',
        ])
      );

      allow delete: if isAdmin();
    }

    match /enquiries/{enquiryId} {
      allow create: if request.resource.data.keys().hasOnly([
        'listingId',
        'dealerId',
        'name',
        'email',
        'phone',
        'message',
        'status',
        'createdAt',
      ]) &&
        request.resource.data.dealerId is string &&
        request.resource.data.listingId is string &&
        request.resource.data.name is string &&
        request.resource.data.email is string &&
        request.resource.data.message is string &&
        request.resource.data.status == 'new' &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.name.size() <= 120 &&
        request.resource.data.email.size() > 0 &&
        request.resource.data.email.size() <= 254 &&
        request.resource.data.message.size() > 0 &&
        request.resource.data.message.size() <= 5000;

      allow read: if isAdmin() || isDealerOwnerById(resource.data.dealerId);
    }

    match /models/{modelId} {
      allow read: if true;

      allow create: if isAdmin() || (
        isAuthenticated() &&
        request.resource.data.ownerUid == request.auth.uid
      );

      allow update: if isAdmin() || (
        isAuthenticated() &&
        resource.data.ownerUid == request.auth.uid &&
        request.resource.data.ownerUid == resource.data.ownerUid
      );

      allow delete: if isAdmin() || (
        isAuthenticated() &&
        resource.data.ownerUid == request.auth.uid
      );
    }

    match /dealerModels/{modelId} {
      allow read: if true;

      allow create: if isAdmin() || (
        isAuthenticated() &&
        isDealerOwnerById(request.resource.data.dealer_id)
      );

      allow update: if isAdmin() || (
        isAuthenticated() &&
        isDealerOwnerById(resource.data.dealer_id)
      );

      allow delete: if isAdmin() || (
        isAuthenticated() &&
        isDealerOwnerById(resource.data.dealer_id)
      );
    }

    match /blogPosts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /charging_stations/{stationId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
