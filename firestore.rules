rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isBlockedAccountData(userData) {
      return (
        ('accountStatus' in userData) &&
        (
          userData.accountStatus == 'suspended' ||
          userData.accountStatus == 'disabled' ||
          userData.accountStatus == 'archived'
        )
      ) || (
        !('accountStatus' in userData) &&
        ('status' in userData) &&
        (
          userData.status == 'suspended' ||
          userData.status == 'disabled' ||
          userData.status == 'archived'
        )
      );
    }

    function getUserDataOrNull() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid))
          ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
          : null;
    }

    function hasActiveUserRecord() {
      let userData = getUserDataOrNull();
      return userData != null && !isBlockedAccountData(userData);
    }

    function isSignedInAndNotBlocked() {
      let userData = getUserDataOrNull();
      return isAuthenticated() && (
        userData == null ||
        !isBlockedAccountData(userData)
      );
    }

    function isUser(userId) {
      return isSignedInAndNotBlocked() && request.auth.uid == userId;
    }

    function hasUserRecord() {
      return getUserDataOrNull() != null;
    }

    function getUserData() {
      return getUserDataOrNull();
    }

    function hasAdminRole(roleId) {
      let userData = getUserDataOrNull();
      return userData != null &&
        !isBlockedAccountData(userData) &&
        ('adminRoleIds' in userData) &&
        userData.adminRoleIds.hasAny([roleId]);
    }

    function hasAnyScopedAdminRole() {
      let userData = getUserDataOrNull();
      return userData != null &&
        !isBlockedAccountData(userData) &&
        ('adminRoleIds' in userData) &&
        userData.adminRoleIds.size() > 0;
    }

    function hasDirectPermission(permission) {
      let userData = getUserDataOrNull();
      return userData != null &&
        !isBlockedAccountData(userData) &&
        ('directPermissions' in userData) &&
        userData.directPermissions[permission] == true;
    }

    function hasFullAdminAccess() {
      let userData = getUserDataOrNull();
      return userData != null &&
        !isBlockedAccountData(userData) &&
        (
          userData.role == 'admin' ||
          userData.accountType == 'admin' ||
          (
            ('isMasterAdmin' in userData) &&
            userData.isMasterAdmin == true
          ) ||
          (
            ('adminRoleIds' in userData) &&
            userData.adminRoleIds.hasAny(['master_admin'])
          )
        );
    }

    function canManageUsers() {
      return hasFullAdminAccess() ||
        hasAdminRole('platform_ops_admin') ||
        hasAdminRole('user_support_admin') ||
        hasDirectPermission('users.edit') ||
        hasDirectPermission('users.suspend') ||
        hasDirectPermission('users.reactivate');
    }

    function canReadUsers() {
      return canManageUsers() || hasDirectPermission('users.read');
    }

    function canManageDealers() {
      return hasFullAdminAccess() ||
        hasAdminRole('platform_ops_admin') ||
        hasAdminRole('dealer_ops_admin') ||
        hasDirectPermission('dealers.edit') ||
        hasDirectPermission('dealers.approve');
    }

    function canReadDealersAdmin() {
      return canManageDealers() ||
        hasAdminRole('user_support_admin') ||
        hasDirectPermission('dealers.read');
    }

    function canManageDealerPlans() {
      return hasFullAdminAccess() ||
        hasAdminRole('platform_ops_admin') ||
        hasAdminRole('dealer_ops_admin') ||
        hasDirectPermission('dealer_plans.assign') ||
        hasDirectPermission('dealer_plans.override');
    }

    function canModerateListings() {
      return hasFullAdminAccess() ||
        hasAdminRole('platform_ops_admin') ||
        hasAdminRole('dealer_ops_admin') ||
        hasDirectPermission('listings.moderate') ||
        hasDirectPermission('listings.reassign');
    }

    function canManageModels() {
      return hasFullAdminAccess() ||
        hasAdminRole('platform_ops_admin') ||
        hasAdminRole('catalog_admin') ||
        hasDirectPermission('models.publish') ||
        hasDirectPermission('models.merge');
    }

    function canManageStations() {
      return hasFullAdminAccess() ||
        hasAdminRole('platform_ops_admin') ||
        hasAdminRole('charging_admin') ||
        hasDirectPermission('stations.edit') ||
        hasDirectPermission('stations.merge');
    }

    function canManageBlog() {
      return hasFullAdminAccess() ||
        hasAdminRole('platform_ops_admin') ||
        hasAdminRole('content_admin') ||
        hasDirectPermission('blog.publish') ||
        hasDirectPermission('blog.schedule');
    }

    function canReadEnquiriesAdmin() {
      return canModerateListings() ||
        hasAdminRole('user_support_admin') ||
        hasDirectPermission('enquiries.read');
    }

    function isDealerStaffForId(dealerId) {
      let userData = getUserDataOrNull();
      return userData != null &&
        !isBlockedAccountData(userData) &&
        userData.accountType == 'dealer_staff' &&
        userData.dealerId == dealerId &&
        (
          !('accountStatus' in userData) ||
          userData.accountStatus == 'active' ||
          userData.accountStatus == 'approved'
        );
    }

    function isDealerOwnerById(dealerId) {
      return isSignedInAndNotBlocked() && (
        dealerId == request.auth.uid ||
        (
          exists(/databases/$(database)/documents/dealers/$(dealerId)) &&
          get(/databases/$(database)/documents/dealers/$(dealerId)).data.ownerUid == request.auth.uid
        )
      );
    }

    function isDealerMemberById(dealerId) {
      return isDealerOwnerById(dealerId) || isDealerStaffForId(dealerId);
    }

    function isDealerOwner(dealerData) {
      return dealerData != null &&
        isSignedInAndNotBlocked() &&
        dealerData.ownerUid == request.auth.uid;
    }

    function isPublicDealer(dealerData) {
      return dealerData != null &&
        dealerData.approved == true &&
        dealerData.isActive == true &&
        dealerData.isDeleted != true;
    }

    function isPublicListing(listingData) {
      return listingData != null &&
        (
          listingData.status == 'approved' ||
          listingData.status == 'active'
        );
    }

    function isListingOwner(listingData) {
      return listingData != null &&
        isSignedInAndNotBlocked() && (
          listingData.ownerUid == request.auth.uid ||
          isDealerMemberById(listingData.dealerId)
        );
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (isUser(userId) || canReadUsers());

      allow create: if isUser(userId) &&
        !exists(/databases/$(database)/documents/users/$(userId)) &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.email == request.auth.token.email &&
        (
          request.resource.data.role == 'user' ||
          request.resource.data.role == 'pending'
        ) &&
        (
          (request.resource.data.role == 'user' &&
            (!('status' in request.resource.data) || request.resource.data.status == 'active')
          ) ||
          (request.resource.data.role == 'pending' &&
            request.resource.data.status == 'pending'
          )
        ) &&
        (
          !('accountType' in request.resource.data) ||
          (request.resource.data.role == 'user' && request.resource.data.accountType == 'user') ||
          (request.resource.data.role == 'pending' &&
            (
              request.resource.data.accountType == 'dealer' ||
              request.resource.data.accountType == 'pending'
            )
          )
        ) &&
        (
          !('accountStatus' in request.resource.data) ||
          (request.resource.data.role == 'user' && request.resource.data.accountStatus == 'active') ||
          (request.resource.data.role == 'pending' && request.resource.data.accountStatus == 'pending')
        ) &&
        (
          !('dealerPlanId' in request.resource.data) ||
          request.resource.data.dealerPlanId == 'free'
        ) &&
        (
          !('dealerSubscriptionStatus' in request.resource.data) ||
          request.resource.data.dealerSubscriptionStatus == 'active'
        ) &&
        !('adminRoleIds' in request.resource.data) &&
        !('directPermissions' in request.resource.data) &&
        !('permissionScopes' in request.resource.data) &&
        !('isMasterAdmin' in request.resource.data);

      allow update: if isUser(userId) &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'role',
          'status',
          'uid',
          'accountType',
          'accountStatus',
          'adminRoleIds',
          'directPermissions',
          'permissionScopes',
          'isMasterAdmin',
          'dealerPlanId',
          'dealerSubscriptionStatus',
        ]);

      allow delete: if canManageUsers();

      match /favourites/{favId} {
        allow read, write: if isUser(userId);
      }
    }

    match /dealers/{dealerId} {
      allow read: if canReadDealersAdmin() || isDealerOwner(resource.data) || isDealerStaffForId(dealerId) || isPublicDealer(resource.data);

      allow create: if canManageDealers() || (
        isAuthenticated() &&
        request.resource.data.ownerUid == request.auth.uid &&
        request.resource.data.approved != true &&
        request.resource.data.isActive != true &&
        request.resource.data.isDeleted != true &&
        request.resource.data.status == 'pending' &&
        (
          !('planId' in request.resource.data) ||
          request.resource.data.planId == 'free'
        ) &&
        (
          !('subscriptionStatus' in request.resource.data) ||
          request.resource.data.subscriptionStatus == 'active'
        )
      );

      allow update: if canManageDealers() || canManageDealerPlans() || (
        (isDealerOwner(resource.data) || isDealerStaffForId(dealerId)) &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'approved',
          'approvedAt',
          'rejectedAt',
          'rejectionReason',
          'isActive',
          'isDeleted',
          'deletedAt',
          'status',
          'ownerUid',
          'createdBy',
          'planId',
          'subscriptionStatus',
        ])
      );

      allow delete: if canManageDealers();
    }

    match /listings/{listingId} {
      allow read: if canModerateListings() || isListingOwner(resource.data) || isPublicListing(resource.data);

      allow create: if canModerateListings() || (
        isAuthenticated() &&
        request.resource.data.ownerUid == request.auth.uid &&
        isDealerMemberById(request.resource.data.dealerId) &&
        request.resource.data.status == 'pending'
      );

      allow update: if canModerateListings() || (
        isListingOwner(resource.data) &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'status',
          'approvedAt',
          'rejectedAt',
          'rejectionReason',
          'dealerId',
          'ownerUid',
        ])
      );

      allow delete: if canModerateListings();
    }

    match /enquiries/{enquiryId} {
      allow create: if hasFullAdminAccess();
      allow read: if canReadEnquiriesAdmin() || isDealerMemberById(resource.data.dealerId);
    }

    match /models/{modelId} {
      allow read: if true;

      allow create: if canManageModels() || (
        isAuthenticated() &&
        request.resource.data.ownerUid == request.auth.uid &&
        (
          !('ownerDealerId' in request.resource.data) ||
          request.resource.data.ownerDealerId == null ||
          isDealerMemberById(request.resource.data.ownerDealerId)
        ) &&
        request.resource.data.reviewStatus == 'pending_review' &&
        request.resource.data.isActive != true &&
        (
          !('submissionSource' in request.resource.data) ||
          request.resource.data.submissionSource == 'dealer'
        ) &&
        (
          !('reviewedAt' in request.resource.data) ||
          request.resource.data.reviewedAt == null
        ) &&
        (
          !('reviewedBy' in request.resource.data) ||
          request.resource.data.reviewedBy == null
        )
      );

      allow update: if canManageModels() || (
        isAuthenticated() &&
        (
          resource.data.reviewStatus == 'pending_review' ||
          resource.data.reviewStatus == 'rejected'
        ) &&
        (
          (
            resource.data.ownerUid == request.auth.uid &&
            request.resource.data.ownerUid == resource.data.ownerUid
          ) ||
          (
            ('ownerDealerId' in resource.data) &&
            resource.data.ownerDealerId != null &&
            isDealerMemberById(resource.data.ownerDealerId) &&
            request.resource.data.ownerDealerId == resource.data.ownerDealerId
          )
        ) &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'reviewStatus',
          'reviewRequestedAt',
          'reviewedAt',
          'reviewedBy',
          'reviewNotes',
          'submissionSource',
        ])
      );

      allow delete: if canManageModels() || (
        isAuthenticated() &&
        (
          resource.data.reviewStatus == 'pending_review' ||
          resource.data.reviewStatus == 'rejected'
        ) &&
        (
          resource.data.ownerUid == request.auth.uid ||
          (
            ('ownerDealerId' in resource.data) &&
            resource.data.ownerDealerId != null &&
            isDealerMemberById(resource.data.ownerDealerId)
          )
        )
      );
    }

    match /dealerModels/{modelId} {
      allow read: if true;

      allow create: if canManageModels() || canManageDealers() || (
        isAuthenticated() &&
        isDealerMemberById(request.resource.data.dealer_id)
      );

      allow update: if canManageModels() || canManageDealers() || (
        isAuthenticated() &&
        isDealerMemberById(resource.data.dealer_id)
      );

      allow delete: if canManageModels() || canManageDealers() || (
        isAuthenticated() &&
        isDealerMemberById(resource.data.dealer_id)
      );
    }

    match /blogPosts/{postId} {
      allow read: if true;
      allow write: if canManageBlog();
    }

    match /charging_stations/{stationId} {
      allow read: if true;
      allow write: if canManageStations();
    }
  }
}
