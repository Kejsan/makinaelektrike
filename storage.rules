rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isBlockedAccountData(userData) {
      return (
        ('accountStatus' in userData) &&
        (
          userData.accountStatus == 'suspended' ||
          userData.accountStatus == 'disabled' ||
          userData.accountStatus == 'archived'
        )
      ) || (
        !('accountStatus' in userData) &&
        ('status' in userData) &&
        (
          userData.status == 'suspended' ||
          userData.status == 'disabled' ||
          userData.status == 'archived'
        )
      );
    }

    function hasActiveUserRecord() {
      return hasUserRecord() &&
        !isBlockedAccountData(getUserData());
    }

    function isSignedInAndNotBlocked() {
      return isAuthenticated() && (
        !hasUserRecord() ||
        hasActiveUserRecord()
      );
    }

    function hasUserRecord() {
      return isAuthenticated() &&
        firestore.exists(/databases/(default)/documents/users/$(request.auth.uid));
    }

    function getUserData() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }

    function hasAdminRole(roleId) {
      return hasActiveUserRecord() &&
        ('adminRoleIds' in getUserData()) &&
        getUserData().adminRoleIds.hasAny([roleId]);
    }

    function hasDirectPermission(permission) {
      return hasActiveUserRecord() &&
        ('directPermissions' in getUserData()) &&
        getUserData().directPermissions[permission] == true;
    }

    function hasFullAdminAccess() {
      return hasActiveUserRecord() && (
        getUserData().role == 'admin' ||
        getUserData().accountType == 'admin' ||
        getUserData().isMasterAdmin == true ||
        hasAdminRole('master_admin')
      );
    }

    function canManageDealers() {
      return hasFullAdminAccess() ||
        hasAdminRole('platform_ops_admin') ||
        hasAdminRole('dealer_ops_admin') ||
        hasDirectPermission('dealers.edit') ||
        hasDirectPermission('dealers.approve');
    }

    function canModerateListings() {
      return hasFullAdminAccess() ||
        hasAdminRole('platform_ops_admin') ||
        hasAdminRole('dealer_ops_admin') ||
        hasDirectPermission('listings.moderate') ||
        hasDirectPermission('listings.reassign');
    }

    function canManageModels() {
      return hasFullAdminAccess() ||
        hasAdminRole('platform_ops_admin') ||
        hasAdminRole('catalog_admin') ||
        hasDirectPermission('models.publish') ||
        hasDirectPermission('models.merge');
    }

    function isDealerStaffForId(dealerId) {
      return hasActiveUserRecord() &&
        getUserData().accountType == 'dealer_staff' &&
        getUserData().dealerId == dealerId &&
        (
          !('accountStatus' in getUserData()) ||
          getUserData().accountStatus == 'active' ||
          getUserData().accountStatus == 'approved'
        );
    }

    function isDealerOwner(dealerId) {
      return isSignedInAndNotBlocked() && (
        dealerId == request.auth.uid ||
        (
          firestore.exists(/databases/(default)/documents/dealers/$(dealerId)) &&
          firestore.get(/databases/(default)/documents/dealers/$(dealerId)).data.ownerUid == request.auth.uid
        )
      );
    }

    function isDealerMember(dealerId) {
      return isDealerOwner(dealerId) || isDealerStaffForId(dealerId);
    }

    function isModelOperator(modelId) {
      return isSignedInAndNotBlocked() &&
        firestore.exists(/databases/(default)/documents/models/$(modelId)) &&
        (
          firestore.get(/databases/(default)/documents/models/$(modelId)).data.ownerUid == request.auth.uid ||
          (
            ('ownerDealerId' in firestore.get(/databases/(default)/documents/models/$(modelId)).data) &&
            firestore.get(/databases/(default)/documents/models/$(modelId)).data.ownerDealerId != null &&
            isDealerMember(firestore.get(/databases/(default)/documents/models/$(modelId)).data.ownerDealerId)
          )
        );
    }

    function isSafeImageUpload() {
      return request.resource != null &&
        request.resource.size < 10 * 1024 * 1024 &&
        request.resource.contentType.matches('image/(jpeg|png|webp|avif|gif)');
    }

    match /listings/{dealerId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSafeImageUpload() && (canModerateListings() || isDealerMember(dealerId));
    }

    match /dealers/{dealerId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSafeImageUpload() && (canManageDealers() || isDealerMember(dealerId));
    }

    match /models/{modelId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSafeImageUpload() && (canManageModels() || isModelOperator(modelId));
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
