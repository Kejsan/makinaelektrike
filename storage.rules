rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isDealerOwner(dealerId) {
      return isAuthenticated() && (
        dealerId == request.auth.uid ||
        (
          firestore.exists(/databases/(default)/documents/dealers/$(dealerId)) &&
          firestore.get(/databases/(default)/documents/dealers/$(dealerId)).data.ownerUid == request.auth.uid
        )
      );
    }

    function isModelOwner(modelId) {
      return isAuthenticated() &&
        firestore.exists(/databases/(default)/documents/models/$(modelId)) &&
        firestore.get(/databases/(default)/documents/models/$(modelId)).data.ownerUid == request.auth.uid;
    }

    function isSafeImageUpload() {
      return request.resource != null &&
        request.resource.size < 10 * 1024 * 1024 &&
        request.resource.contentType.matches('image/(jpeg|png|webp|avif|gif)');
    }

    match /listings/{dealerId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSafeImageUpload() && (isAdmin() || isDealerOwner(dealerId));
    }

    match /dealers/{dealerId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSafeImageUpload() && (isAdmin() || isDealerOwner(dealerId));
    }

    match /models/{modelId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSafeImageUpload() && (isAdmin() || isModelOwner(modelId));
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
